# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Lấy từ: https://supabase.com/dashboard
# Vào project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# ============================================
# JWT SECRET
# ============================================
# Tạo random key bằng lệnh:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-random-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256

# ============================================
# GOOGLE OAUTH CREDENTIALS
# ============================================
# Lấy từ: https://console.cloud.google.com/apis/credentials
# Tạo OAuth 2.0 Client ID với redirect URI: http://localhost:3000/auth/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here

# ============================================
# OPTIONAL SETTINGS
# ============================================
# Ollama (nếu chạy remote)
# OLLAMA_BASE_URL=http://localhost:11434

# Environment mode
# ENV=development

# CORS origins (Frontend URLs)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001
